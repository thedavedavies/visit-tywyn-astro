# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# Per-run artifacts from the compound-engineering ce:review skill.
# These are debug output, not source. Re-running ce:review creates
# a new timestamped directory each time.
.context/

# Migrated images — populated by `npm run migrate:uploads`. We don't
# commit the year-bucketed legacy binaries; keep them outside git and
# either copy them onto the host at deploy time, or migrate to S3/R2/etc.
public/img/20*/

# Export script's dotfiles (regenerated each run)
tools/.export-report.json
tools/.upload-references.txt
