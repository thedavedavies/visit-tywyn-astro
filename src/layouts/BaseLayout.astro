---
/**
 * Root layout. Owns the entire `<html>` tree.
 *
 * Header order intentionally mirrors the Capo.js-inspired ordering
 * from header.php: charset > viewport > title > preconnect > styles
 * > scripts > icons > meta.
 *
 * Pages pass page-specific schema via `jsonLd` (object or array).
 * We additionally auto-emit a BreadcrumbList whenever `breadcrumbs`
 * is non-empty so individual pages don't have to remember to do it.
 *
 * JSON-LD is emitted via `safeJsonLd` (escapes `</`) so that
 * editor-controlled strings — venue titles, addresses, breadcrumb
 * labels, event names — can't break out of the script block.
 */
import '../styles/global.scss';
import { Font } from 'astro:assets';
import Header from '../components/Header/Header.astro';
import Footer from '../components/Footer/Footer.astro';
import { SITE } from '../lib/site';
import { breadcrumbList, organization, website } from '../lib/jsonld';
import { absoluteUrl, safeJsonLd } from '../lib/url';

interface BreadcrumbItem {
	label: string;
	href?: string;
}

interface Props {
	title: string;
	description?: string;
	canonical?: string | URL;
	ogImage?: string;
	noindex?: boolean;
	heroImage?: { src: string; alt?: string } | null;
	breadcrumbs?: BreadcrumbItem[];
	isFrontPage?: boolean;
	bodyClass?: string;
	jsonLd?: Record<string, unknown> | (Record<string, unknown> | null | undefined)[];
	publishedTime?: string;
	modifiedTime?: string;
}

const {
	title,
	description = SITE.description,
	canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url),
	ogImage,
	noindex = false,
	heroImage = null,
	breadcrumbs = [],
	isFrontPage = false,
	bodyClass = '',
	jsonLd,
	publishedTime,
	modifiedTime,
} = Astro.props;

const fullTitle = isFrontPage ? `${SITE.name} | ${SITE.tagline}` : `${title} | ${SITE.name}`;
const canonicalHref = canonical instanceof URL ? canonical.toString() : canonical;
const resolvedOgImage = absoluteUrl(ogImage ?? SITE.defaultOgImage);
const ogType = isFrontPage ? 'website' : 'article';

// Site identity schemas emit on every page. Yoast did the same on
// WordPress; without them on subpages, sitelinks search box and
// brand/Knowledge Graph signals are weaker than they were pre-launch.
// `Organization` is referenced by `WebSite.publisher` via @id, so
// emit both together to keep the graph self-consistent.
const autoSchema: Record<string, unknown>[] = [organization(), website()];
const crumbSchema = breadcrumbList(breadcrumbs, canonicalHref);
if (crumbSchema) autoSchema.push(crumbSchema);

const pageSchema = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
// Builders return null when there's nothing to emit (empty input).
// Filter those out so we don't ship `<script>null</script>`. Dedup
// by `@id` so a page that emits its own Organization or WebSite
// (e.g. the home page, historically) doesn't ship duplicates.
const seenIds = new Set<string>();
const jsonLdBlocks = [...autoSchema, ...pageSchema]
	.filter((block): block is Record<string, unknown> => block != null)
	.filter((block) => {
		const id = typeof block['@id'] === 'string' ? (block['@id'] as string) : null;
		if (!id) return true;
		if (seenIds.has(id)) return false;
		seenIds.add(id);
		return true;
	});
---

<!doctype html>
<html lang="en-GB">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalHref} />
		{
			noindex ? (
				<meta name="robots" content="noindex, nofollow" />
			) : (
				<meta
					name="robots"
					content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
				/>
			)
		}

		<meta name="theme-color" content={SITE.themeColor} />
		<meta name="format-detection" content="telephone=no" />

		<link rel="preconnect" href="https://www.googletagmanager.com" />
		<link rel="preconnect" href="https://pagead2.googlesyndication.com" />
		<link rel="dns-prefetch" href="https://analytics.ahrefs.com" />

		<Font cssVariable="--font-body" preload={[{ weight: 400, style: 'normal', subset: 'latin' }]} />

		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalHref} />
		<meta property="og:site_name" content={SITE.name} />
		<meta property="og:locale" content={SITE.locale} />
		{resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
		{resolvedOgImage && <meta property="og:image:alt" content={`${title} – ${SITE.name}`} />}
		{/*
		 * og:image:width / og:image:height intentionally omitted.
		 * The default OG image is 1908x397 — outside the 1.91:1 / 2:1
		 * range social platforms expect. Letting them probe and crop
		 * gracefully is preferable to declaring dimensions that
		 * misrepresent the asset. Follow-up: generate a 1200x630
		 * social card and re-add the meta tags + dimensions.
		 */}
		{publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
		<meta name="twitter:card" content={resolvedOgImage ? 'summary_large_image' : 'summary'} />
		{SITE.twitter && <meta name="twitter:site" content={SITE.twitter} />}

		<link rel="icon" href="https://visit-tywyn.s3.amazonaws.com/favicon.ico" />
		<link rel="profile" href="https://gmpg.org/xfn/11" />
		<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

		{
			SITE.gaMeasurementId && (
				<>
					<script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.gaMeasurementId}`} />
					<script is:inline define:vars={{ gaId: SITE.gaMeasurementId }}>
						window.dataLayer = window.dataLayer || [];
						function gtag() {
							dataLayer.push(arguments);
						}
						gtag('js', new Date());
						gtag('config', gaId);
					</script>
				</>
			)
		}
		<script
			defer
			src="https://analytics.ahrefs.com/analytics.js"
			data-key="RHUgFDUqpEFNoIEFLipsjA"></script>

		<script
			defer
			src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${SITE.adsenseClient}`}
			crossorigin="anonymous"></script>

		{
			jsonLdBlocks.map((block) => (
				<script type="application/ld+json" set:html={safeJsonLd(block)} />
			))
		}
	</head>

	<body class={bodyClass}>
		<div id="page">
			<Header heroImage={heroImage} breadcrumbs={breadcrumbs} />
			<main id="primary" class="site-main">
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
