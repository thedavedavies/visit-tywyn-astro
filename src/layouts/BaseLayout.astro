---
/**
 * Root layout. Owns the entire `<html>` tree.
 *
 * Header order intentionally mirrors the Capo.js-inspired ordering
 * from header.php: charset > viewport > title > preconnect > styles
 * > scripts > icons > meta.
 *
 * Pages pass page-specific schema via `jsonLd` (object or array).
 * We additionally auto-emit a BreadcrumbList whenever `breadcrumbs`
 * is non-empty so individual pages don't have to remember to do it.
 *
 * JSON-LD is emitted via `safeJsonLd` (escapes `</`) so that
 * editor-controlled strings - venue titles, addresses, breadcrumb
 * labels, event names - can't break out of the script block.
 */
import '../styles/global.scss';
import { Font } from 'astro:assets';
import Header from '../components/Header/Header.astro';
import Footer from '../components/Footer/Footer.astro';
import type { ImageMetadata } from 'astro';
import { SITE } from '../lib/site';
import { breadcrumbList, organization, website } from '../lib/jsonld';
import { absoluteUrl, safeJsonLd } from '../lib/url';
import defaultOgImageSrc from '../assets/img/site/og-default.jpg';

interface BreadcrumbItem {
	label: string;
	href?: string;
}

interface Props {
	title: string;
	description?: string;
	canonical?: string | URL;
	ogImage?: string;
	noindex?: boolean;
	heroImage?: { src: ImageMetadata; alt?: string } | null;
	breadcrumbs?: BreadcrumbItem[];
	isFrontPage?: boolean;
	bodyClass?: string;
	jsonLd?: Record<string, unknown> | (Record<string, unknown> | null | undefined)[];
	publishedTime?: string;
	modifiedTime?: string;
	/**
	 * Whether the page will render at least one AdSlot. Controls
	 * inclusion of the AdSense library script. Defaults to true
	 * because every page that uses PageLayout ships a sidebar
	 * AdSlot; pages that opt out of the sidebar (e.g. /404/) should
	 * pass `hasAds={false}` to avoid downloading ~30 KB of script
	 * that will have nothing to push to.
	 */
	hasAds?: boolean;
}

const {
	title,
	description = SITE.description,
	canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url),
	ogImage,
	noindex = false,
	heroImage = null,
	breadcrumbs = [],
	isFrontPage = false,
	bodyClass = '',
	jsonLd,
	publishedTime,
	modifiedTime,
	hasAds = true,
} = Astro.props;

// Title formatting: every page is `<page-specific> | Visit Tywyn`,
// home included. The previous home-only special case (which rendered
// `Visit Tywyn | <tagline>` without the page title) drifted from the
// Yoast-indexed WP title; now the home page passes its own title and
// we get a consistent, SEO-preserving format everywhere.
const fullTitle = `${title} | ${SITE.name}`;
const canonicalHref = canonical instanceof URL ? canonical.toString() : canonical;
// OG images need an absolute URL on the social-card platform's
// crawl. If the page didn't pass one in, fall back to the default
// social card asset (Astro processes it and gives us a content-
// hashed `/_astro/...` URL we then absolutise).
const resolvedOgImage = absoluteUrl(ogImage ?? defaultOgImageSrc.src);
const ogType = isFrontPage ? 'website' : 'article';

// Site identity schemas emit on every page. Yoast did the same on
// WordPress; without them on subpages, sitelinks search box and
// brand/Knowledge Graph signals are weaker than they were pre-launch.
// `Organization` is referenced by `WebSite.publisher` via @id, so
// emit both together to keep the graph self-consistent.
const autoSchema: Record<string, unknown>[] = [organization(), website()];
// Match Yoast: every URL ships at least a `[Home]` BreadcrumbList,
// including the front page itself. The visible <Breadcrumbs>
// component still receives the page's original `breadcrumbs` prop
// (empty on the home page) so the visual trail does not appear with
// a lone "Home" entry; this synthesis is JSON-LD only.
const crumbItems =
	breadcrumbs.length > 0 ? breadcrumbs : isFrontPage ? [{ label: 'Home' }] : [];
const crumbSchema = breadcrumbList(crumbItems, canonicalHref);
if (crumbSchema) autoSchema.push(crumbSchema);

const pageSchema = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
// Builders return null when there's nothing to emit (empty input).
// Filter those out so we don't ship `<script>null</script>`. Dedup
// by `@id` so a page that emits its own Organization or WebSite
// (e.g. the home page, historically) doesn't ship duplicates.
const seenIds = new Set<string>();
const jsonLdBlocks = [...autoSchema, ...pageSchema]
	.filter((block): block is Record<string, unknown> => block != null)
	.filter((block) => {
		const id = typeof block['@id'] === 'string' ? (block['@id'] as string) : null;
		if (!id) return true;
		if (seenIds.has(id)) return false;
		seenIds.add(id);
		return true;
	});
---

<!doctype html>
<html lang="en-GB">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalHref} />
		{
			noindex ? (
				<meta name="robots" content="noindex, nofollow" />
			) : (
				<meta
					name="robots"
					content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
				/>
			)
		}

		{SITE.gscVerification && (
			<meta name="google-site-verification" content={SITE.gscVerification} />
		)}

		<meta name="theme-color" content={SITE.themeColor} />
		<meta name="format-detection" content="telephone=no" />

		<link rel="preconnect" href="https://www.googletagmanager.com" />
		<link rel="preconnect" href="https://pagead2.googlesyndication.com" />
		<link rel="dns-prefetch" href="https://analytics.ahrefs.com" />

		<Font cssVariable="--font-body" preload={[{ weight: 400, style: 'normal', subset: 'latin' }]} />

		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalHref} />
		<meta property="og:site_name" content={SITE.name} />
		<meta property="og:locale" content={SITE.ogLocale} />
		{resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
		{resolvedOgImage && <meta property="og:image:alt" content={`${title} – ${SITE.name}`} />}
		{/*
		 * og:image:width / og:image:height intentionally omitted.
		 * The default OG image is 1908x397 - outside the 1.91:1 / 2:1
		 * range social platforms expect. Letting them probe and crop
		 * gracefully is preferable to declaring dimensions that
		 * misrepresent the asset. Follow-up: generate a 1200x630
		 * social card and re-add the meta tags + dimensions.
		 */}
		{publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
		<meta name="twitter:card" content={resolvedOgImage ? 'summary_large_image' : 'summary'} />
		{SITE.twitter && <meta name="twitter:site" content={SITE.twitter} />}

		<link rel="icon" href="/favicon.ico" />
		{/*
		 * SVG favicon variant intentionally not declared: the WP site
		 * ships only the multi-resolution `.ico` (16x16 + 32x32) and
		 * the default Astro starter SVG was the wrong brand mark.
		 * Drop a real brand-matching SVG into `public/favicon.svg`
		 * and re-add the `<link rel="icon" type="image/svg+xml">`
		 * here when one exists.
		 */}
		<link rel="profile" href="https://gmpg.org/xfn/11" />
		<link rel="sitemap" type="application/xml" href="/sitemap_index.xml" />

		{
			/*
			 * GA4 gating: only fire on the canonical production host.
			 *
			 *   - `import.meta.env.PROD` strips the block entirely from
			 *     `astro dev` builds, so the development server never
			 *     ships a tag or queues a beacon.
			 *   - At runtime the inline script checks `location.host`
			 *     against the canonical site host, so `astro preview`
			 *     on localhost and Cloudflare branch/preview deploys
			 *     (e.g. `*.pages.dev`) load the page without injecting
			 *     the gtag library or hitting Google's collect endpoint.
			 *
			 * Only when both checks pass does the script element get
			 * appended and the page_view fire. Saves the ~80 KB library
			 * fetch on every non-prod render and keeps preview traffic
			 * out of the GA4 property.
			 */
			SITE.gaMeasurementId && import.meta.env.PROD && (
				<script
					is:inline
					define:vars={{ gaId: SITE.gaMeasurementId, productionHost: new URL(SITE.url).host }}
				>
					if (location.host === productionHost) {
						const s = document.createElement('script');
						s.async = true;
						s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
						document.head.appendChild(s);
						window.dataLayer = window.dataLayer || [];
						function gtag() {
							dataLayer.push(arguments);
						}
						gtag('js', new Date());
						gtag('config', gaId);
					}
				</script>
			)
		}
		{
			/*
			 * Ahrefs Web Analytics: gated identically to GA4 above.
			 *
			 *   - `import.meta.env.PROD` drops the tag from `astro dev`
			 *     builds entirely.
			 *   - The runtime `location.host` check keeps it off
			 *     `astro preview` and Cloudflare branch/preview deploys
			 *     (`*.pages.dev`), which are prod builds served on a
			 *     non-canonical host. Only the canonical production host
			 *     injects the script, so preview traffic stays out of
			 *     the Ahrefs project. The `data-key` is set on the
			 *     injected element so analytics.js reads it the same way
			 *     it would from the original static tag.
			 */
			import.meta.env.PROD && (
				<script
					is:inline
					define:vars={{
						ahrefsKey: 'RHUgFDUqpEFNoIEFLipsjA',
						productionHost: new URL(SITE.url).host,
					}}
				>
					if (location.host === productionHost) {
						const s = document.createElement('script');
						s.async = true;
						s.src = 'https://analytics.ahrefs.com/analytics.js';
						s.setAttribute('data-key', ahrefsKey);
						document.head.appendChild(s);
					}
				</script>
			)
		}

		{
			SITE.adsenseClient && hasAds && (
				<script
					defer
					src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${SITE.adsenseClient}`}
					crossorigin="anonymous"
				/>
			)
		}

		{
			jsonLdBlocks.map((block) => (
				<script type="application/ld+json" set:html={safeJsonLd(block)} />
			))
		}
	</head>

	<body class={bodyClass}>
		<a class="skip-link" href="#primary">Skip to content</a>
		<div id="page">
			<Header heroImage={heroImage} breadcrumbs={breadcrumbs} />
			<main id="primary" class="site-main" tabindex="-1">
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
