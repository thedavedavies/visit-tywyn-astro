---
/**
 * Primary navigation. Replaces wp_nav_menu().
 *
 * Toggle behaviour: hidden by default on mobile; revealed by a
 * button click which flips `aria-expanded` and adds the `.toggled`
 * class to the nav (matching the legacy Underscores convention).
 * On desktop the menu is always visible and the toggle is hidden.
 */
import { PRIMARY_NAV } from '../../lib/nav';
import styles from './Nav.module.scss';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
	if (href === '/') return currentPath === '/';
	return currentPath === href || currentPath.startsWith(href);
}
---

<nav id="site-navigation" class={styles.nav} aria-label="Primary">
	<button
		type="button"
		class={styles.toggle}
		aria-controls="primary-menu"
		aria-expanded="false"
		data-vt-nav-toggle
	>
		Primary Menu
	</button>
	<ul id="primary-menu" class={styles.menu}>
		{
			PRIMARY_NAV.map((item) => (
				<li
					class:list={[
						styles.item,
						{ [styles.itemActive]: isActive(item.href) },
						{ [styles.hasChildren]: item.children && item.children.length > 0 },
					]}
				>
					<a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
						{item.label}
						{item.children && item.children.length > 0 && (
							<span aria-hidden="true"> ▼</span>
						)}
					</a>
					{item.children && item.children.length > 0 && (
						<ul class={styles.subMenu}>
							{item.children.map((child) => (
								<li class:list={[styles.subItem, { [styles.subItemActive]: isActive(child.href) }]}>
									<a href={child.href} aria-current={isActive(child.href) ? 'page' : undefined}>
										{child.label}
									</a>
								</li>
							))}
						</ul>
					)}
				</li>
			))
		}
	</ul>
</nav>

<script is:inline>
	(() => {
		const toggle = document.querySelector('[data-vt-nav-toggle]');
		const menu = document.getElementById('primary-menu');
		if (!toggle || !menu) return;
		toggle.addEventListener('click', () => {
			const expanded = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', String(!expanded));
			menu.classList.toggle('is-open', !expanded);
		});
	})();
</script>
