---
/**
 * Primary navigation. Replaces wp_nav_menu().
 *
 * Toggle behaviour: hidden by default on mobile; revealed by a
 * button click which flips `aria-expanded` and adds the `.is-open`
 * class to the nav (matching the legacy Underscores convention).
 * On desktop the menu is always visible and the toggle is hidden.
 *
 * Submenu accessibility: this is a disclosure pattern, not a menu.
 * Items with children get `aria-expanded` on the parent link (no
 * `aria-haspopup`, because that would promise a `role="menu"`
 * popup with arrow-key navigation which we deliberately do not
 * implement: the popup is a plain navigation list of anchors).
 * CSS reveals the submenu on `:hover` and `:focus-within`; the
 * JS at the bottom manages `aria-expanded` state and closes the
 * submenu on focusout so assistive tech stays in sync with what's
 * visible. WAI-ARIA APG calls this the "disclosure" pattern:
 * https://www.w3.org/WAI/ARIA/apg/patterns/disclosure/
 */
import { PRIMARY_NAV } from '../../lib/nav';
import styles from './Nav.module.scss';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
	if (href === '/') return currentPath === '/';
	return currentPath === href || currentPath.startsWith(href);
}
---

<nav id="site-navigation" class={styles.nav} aria-label="Primary">
	<button
		type="button"
		class={styles.toggle}
		aria-controls="primary-menu"
		aria-expanded="false"
		data-vt-nav-toggle
	>
		Primary Menu
	</button>
	<ul id="primary-menu" class={styles.menu}>
		{
			PRIMARY_NAV.map((item) => {
				const hasChildren = !!item.children && item.children.length > 0;
				return (
					<li
						class:list={[
							styles.item,
							{ [styles.itemActive]: isActive(item.href) },
							{ [styles.hasChildren]: hasChildren },
						]}
					>
						<a
							href={item.href}
							aria-current={isActive(item.href) ? 'page' : undefined}
							aria-expanded={hasChildren ? 'false' : undefined}
							data-vt-submenu-trigger={hasChildren ? '' : undefined}
						>
							{item.label}
							{hasChildren && <span aria-hidden="true"> ▼</span>}
						</a>
						{hasChildren && (
							<ul class={styles.subMenu}>
								{item.children!.map((child) => (
									<li
										class:list={[styles.subItem, { [styles.subItemActive]: isActive(child.href) }]}
									>
										<a href={child.href} aria-current={isActive(child.href) ? 'page' : undefined}>
											{child.label}
										</a>
									</li>
								))}
							</ul>
						)}
					</li>
				);
			})
		}
	</ul>
</nav>

<script is:inline>
	(() => {
		const toggle = document.querySelector('[data-vt-nav-toggle]');
		const menu = document.getElementById('primary-menu');
		if (!toggle || !menu) return;
		const setExpanded = (open) => {
			toggle.setAttribute('aria-expanded', String(open));
			menu.classList.toggle('is-open', open);
		};
		toggle.addEventListener('click', () => {
			const expanded = toggle.getAttribute('aria-expanded') === 'true';
			setExpanded(!expanded);
		});

		// Disclosure state. Each parent link marked with the
		// `data-vt-submenu-trigger` attribute owns the `aria-expanded`
		// flag for its sibling `<ul>`. Hover is handled in CSS; focus
		// we sync here so screen readers announce the disclosed state.
		// `focusout` with relatedTarget outside the parent <li> closes
		// the menu so tabbing past the last child doesn't leave a
		// phantom-open state.
		const triggers = document.querySelectorAll('[data-vt-submenu-trigger]');
		triggers.forEach((trigger) => {
			const li = trigger.closest('li');
			if (!li) return;
			const open = () => trigger.setAttribute('aria-expanded', 'true');
			const close = () => trigger.setAttribute('aria-expanded', 'false');
			trigger.addEventListener('focus', open);
			li.addEventListener('mouseenter', open);
			li.addEventListener('mouseleave', close);
			li.addEventListener('focusout', (event) => {
				const next = event.relatedTarget;
				if (next instanceof Node && li.contains(next)) return;
				close();
			});
		});

		// Close on Escape and return focus to the toggle so keyboard
		// users aren't stranded inside the dismissed menu's DOM.
		document.addEventListener('keydown', (event) => {
			if (event.key !== 'Escape') return;
			// Close the open submenu, if any.
			const openTrigger = document.querySelector('[data-vt-submenu-trigger][aria-expanded="true"]');
			if (openTrigger instanceof HTMLElement) {
				openTrigger.setAttribute('aria-expanded', 'false');
				openTrigger.focus();
				return;
			}
			if (toggle.getAttribute('aria-expanded') !== 'true') return;
			setExpanded(false);
			toggle.focus();
		});
	})();
</script>
