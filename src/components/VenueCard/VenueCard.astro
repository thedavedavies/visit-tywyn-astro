---
/**
 * Horizontal list row for an `eating` venue.
 *
 * Mirrors the legacy `archive-eating.php` markup:
 *   - image left (large-4 columns)
 *   - title + address + intro right (large-8 columns)
 *   - dotted blue 1px border-bottom between items
 *
 * Used by /eating/ and /dog-friendly-cafes/. The dog-friendly
 * variant in the legacy theme uses a `.cafe-list` style with
 * solid border and 250px image cap; I've consolidated the two
 * into one component because the differences are cosmetic.
 */
import Icon from '../Icon/Icon.astro';
import styles from './VenueCard.module.scss';

interface Props {
	href: string;
	title: string;
	summary?: string;
	address?: string;
	photo?: { src: string; alt?: string };
	headingLevel?: 2 | 3;
}

const { href, title, summary, address, photo, headingLevel = 3 } = Astro.props;
const HTag = `h${headingLevel}` as 'h2' | 'h3';
---

<article class={styles.row}>
	<a href={href} class={styles.media}>
		{photo && <img src={photo.src} alt={photo.alt ?? title} loading="lazy" />}
	</a>
	<div class={styles.body}>
		<HTag class={styles.title}>
			<a href={href}>{title}</a>
		</HTag>
		{
			address && (
				<p class={styles.address}>
					<Icon name="marker" />
					<span>{address}</span>
				</p>
			)
		}
		{summary && <p class={styles.summary}>{summary}</p>}
	</div>
</article>
