---
/**
 * Horizontal listing row used on archive pages.
 *
 * Image left (1/3), title + optional address + summary right.
 * Dotted blue 1px border-bottom between rows. Used by eating,
 * things-to-do, and dog-friendly-cafes archives.
 */
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Icon from '../Icon/Icon.astro';
import styles from './ListingCard.module.scss';

interface Props {
	href: string;
	title: string;
	summary?: string;
	address?: string;
	image?: { src: ImageMetadata; alt?: string };
	headingLevel?: 2 | 3;
	/**
	 * Eager-load the image with fetchpriority=high. Pass for the first
	 * card or two on an archive: the hero banner renders as a thin
	 * strip on phones, so the first card image is the mobile LCP
	 * element (Lighthouse 2026-07-13 on live /eating/: LCP 4.4s with
	 * 643ms of lazy-discovery Load Delay on exactly this image).
	 * Cards further down should stay lazy.
	 */
	eager?: boolean;
}

const { href, title, summary, address, image, headingLevel = 3, eager = false } = Astro.props;
const HTag = `h${headingLevel}` as 'h2' | 'h3';
---

<article class={styles.row}>
	<a href={href} class={styles.media} aria-hidden="true" tabindex="-1">
		{
			image && (
				<Picture
					src={image.src}
					alt={image.alt ?? title}
					loading={eager ? 'eager' : 'lazy'}
					fetchpriority={eager ? 'high' : undefined}
					formats={['avif', 'webp']}
					widths={[320, 480, 640]}
					sizes="(min-width: 768px) 320px, 100vw"
				/>
			)
		}
	</a>
	<div class={styles.body}>
		<HTag class={styles.title}>
			<a href={href}>{title}</a>
		</HTag>
		{
			address && (
				<p class={styles.address}>
					<Icon name="marker" />
					<span>{address}</span>
				</p>
			)
		}
		{summary && <p class={styles.summary}>{summary}</p>}
	</div>
</article>
