---
import EventCard from './EventCard.astro';
import { upcomingEvents } from '../../lib/events';

interface Props {
	limit?: number;
	title?: string;
	intro?: string;
	sectionId?: string;
	className?: string;
	showAllLink?: boolean;
}

const {
	limit,
	title = 'Upcoming events in Tywyn',
	intro = 'Plan your visit around the next events taking place in Tywyn and nearby.',
	sectionId = 'vt-events',
	className,
	showAllLink = false,
} = Astro.props;

const events = upcomingEvents(limit);
---

<section
	id={sectionId}
	class:list={['vt-events-section', className]}
	aria-labelledby={`${sectionId}-title`}
>
	<header class="vt-events-section__header">
		<h2 id={`${sectionId}-title`}>{title}</h2>
		{intro && <p class="vt-events-section__intro">{intro}</p>}
	</header>
	{
		events.length === 0 ? (
			<p class="vt-events-section__empty">
				There are no upcoming events listed at the moment — check back soon.
			</p>
		) : (
			<>
				<ul class="vt-events-section__list" role="list">
					{events.map((event) => (
						<li>
							<EventCard event={event} />
						</li>
					))}
				</ul>
				{showAllLink && (
					<p class="vt-events-section__cta">
						<a href="/events/">See all upcoming Tywyn events →</a>
					</p>
				)}
			</>
		)
	}
</section>
