---
/**
 * Reusable wrapper for the dark-teal sidebar widgets.
 *
 * Mirrors the WP `.widget-area .sidebar-box` markup: a dark-grey
 * header bar with a green icon chip and a title, followed by a
 * teal body. Use the `iconName` prop for the standard chip; pass
 * children into the default slot for the body.
 */
import Icon from '../Icon/Icon.astro';
import styles from './SidebarBox.module.scss';

interface Props {
	title: string;
	iconName?: string;
	headingLevel?: 2 | 3;
	tone?: 'primary' | 'plain';
}

// Default to H2 because the sidebar sits next to the main entry,
// whose own subheadings are H2. The previous H3 default produced an
// H1 -> H3 jump on pages whose main column had no intervening H2
// (the home page, /contact/, /where-to-stay/, /dog-friendly-cafes/
// and similar). Callers nested inside an already-H2 section can
// pass `headingLevel={3}` explicitly.
const { title, iconName = 'marker', headingLevel = 2, tone = 'primary' } = Astro.props;
const HTag: 'h2' | 'h3' = headingLevel === 2 ? 'h2' : 'h3';
---

<div class:list={[styles.box, styles[tone]]}>
	<div class={styles.header}>
		<HTag class={styles.heading}>
			<span class={styles.iconChip}>
				<Icon name={iconName} />
			</span>
			{title}
		</HTag>
	</div>
	<div class={styles.body}>
		<slot />
	</div>
</div>
