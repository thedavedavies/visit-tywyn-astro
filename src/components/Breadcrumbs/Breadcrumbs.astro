---
/**
 * Replaces yoast_breadcrumb(). Each page passes its own breadcrumb
 * trail via props — we don't try to derive it from URL structure
 * because some pages (where-to-stay, dog-friendly-cafes) want
 * curated trails.
 */
import styles from './Breadcrumbs.module.scss';

interface Item {
	label: string;
	href?: string;
}

interface Props {
	items: Item[];
}

const { items } = Astro.props;
---

{
	items.length > 0 && (
		<nav class={styles.container} aria-label="Breadcrumb">
			<ol class={styles.list}>
				{items.map((item, idx) => {
					const isLast = idx === items.length - 1;
					return (
						<li class={styles.item}>
							{item.href && !isLast ? (
								<a href={item.href}>{item.label}</a>
							) : (
								<span aria-current={isLast ? 'page' : undefined}>{item.label}</span>
							)}
							{!isLast && <span class={styles.separator} aria-hidden="true">»</span>}
						</li>
					);
				})}
			</ol>
		</nav>
	)
}
