---
/**
 * Replaces yoast_breadcrumb(). Each page passes its own breadcrumb
 * trail in via props — we don't try to derive it from URL structure
 * because some pages (where-to-stay, dog-friendly-cafes) want
 * curated trails.
 */
interface Item {
	label: string;
	href?: string;
}

interface Props {
	items: Item[];
}

const { items } = Astro.props;

if (items.length === 0) {
	// nothing to render
}
---

{
	items.length > 0 && (
		<nav class="breadcrumbs-container" aria-label="Breadcrumb">
			<p id="breadcrumbs">
				{items.map((item, idx) => {
					const isLast = idx === items.length - 1;
					return (
						<>
							{item.href && !isLast ? <a href={item.href}>{item.label}</a> : <span aria-current={isLast ? 'page' : undefined}>{item.label}</span>}
							{!isLast && <span class="separator" aria-hidden="true"> » </span>}
						</>
					);
				})}
			</p>
		</nav>
	)
}
