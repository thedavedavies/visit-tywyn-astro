---
/**
 * Aggregate sidebar. Pages opt into the boxes they need via props.
 *
 * Note: the original WP sidebar had an `accommodation-details` box —
 * removed in this port because individual accommodation listings
 * have been retired in favour of category landing pages.
 */
import Icon from '../ui/Icon.astro';
import WeatherWidget from '../conditions/WeatherWidget.astro';
import TidesWidget from '../conditions/TidesWidget.astro';
import { SITE } from '../../lib/site';

interface ThingsToDoInfo {
	title: string;
	website?: string;
	phone?: string;
	grid_reference?: string;
}

interface EatingInfo {
	title: string;
	trip_advisor_link?: string;
	facebook_link?: string;
	dog_friendly?: boolean;
	website?: string;
	phone?: string;
}

interface Props {
	thingsToDo?: ThingsToDoInfo;
	eating?: EatingInfo;
	showWeather?: boolean;
	showTides?: boolean;
	showAds?: boolean;
}

const {
	thingsToDo,
	eating,
	showWeather = true,
	showTides = true,
	showAds = true,
} = Astro.props;

const newTabNotice = '<span class="sr-only"> (opens in new tab)</span>';
---

<aside class="widget-area" aria-label="Sidebar">
	{
		thingsToDo && (thingsToDo.website || thingsToDo.phone || thingsToDo.grid_reference) && (
			<div class="sidebar-box">
				<div class="header">
					<h3>
						<Icon name="marker" /> {thingsToDo.title} Information
					</h3>
				</div>
				<div class="contact-info">
					{thingsToDo.website && (
						<div class="single">
							<Icon name="link" />
							<a target="_blank" rel="noopener noreferrer" href={thingsToDo.website}>
								{thingsToDo.website}
								<Fragment set:html={newTabNotice} />
							</a>
						</div>
					)}
					{thingsToDo.phone && (
						<div class="single">
							<Icon name="phone" />
							{thingsToDo.phone}
						</div>
					)}
					{thingsToDo.grid_reference && (
						<div class="single">
							<Icon name="marker" />
							Grid reference: {thingsToDo.grid_reference}
						</div>
					)}
				</div>
			</div>
		)
	}

	{
		eating && (eating.trip_advisor_link || eating.facebook_link || eating.dog_friendly) && (
			<div class="eating-details-box">
				<h2 class="leadTitle">{eating.title} Details</h2>
				<div class="restaurant-info">
					<ul class="icons">
						{eating.trip_advisor_link && (
							<li>
								<a href={eating.trip_advisor_link} target="_blank" rel="noopener noreferrer">
									<Icon name="tripadvisor" />
									<span>{eating.title} on Trip Advisor</span>
									<Fragment set:html={newTabNotice} />
								</a>
							</li>
						)}
						{eating.facebook_link && (
							<li>
								<a href={eating.facebook_link} target="_blank" rel="noopener noreferrer">
									<Icon name="facebook" />
									<span>{eating.title} on Facebook</span>
									<Fragment set:html={newTabNotice} />
								</a>
							</li>
						)}
					</ul>
					{eating.dog_friendly && (
						<div class="dog-friendly-pill">
							<Icon name="paw" /> <span>Dog friendly</span>
						</div>
					)}
					<div class="eating-data">
						{eating.website && (
							<p>
								<a target="_blank" rel="noopener noreferrer" href={eating.website}>
									{eating.website}
									<Fragment set:html={newTabNotice} />
								</a>
							</p>
						)}
						{eating.phone && <p>Phone: {eating.phone}</p>}
					</div>
				</div>
			</div>
		)
	}

	<div class="sidebar-box">
		<div class="header">
			<h3><Icon name="marker" />Plan your visit to Tywyn</h3>
		</div>
		<div class="content">
			<ul>
				<li><a href="/cinema/">Tywyn Cinema</a></li>
				<li><a href="/webcam/">Seafront Webcam</a></li>
				<li><a href="/dog-friendly-cafes/">Dog friendly cafes</a></li>
			</ul>
		</div>
	</div>

	{
		showWeather && (
			<div class="sidebar-box">
				<div class="header">
					<h3><Icon name="marker" />Tywyn beach weather</h3>
				</div>
				<div class="content">
					<div class="sidebar-conditions">
						<WeatherWidget />
					</div>
				</div>
			</div>
		)
	}

	{
		showTides && (
			<div class="sidebar-box">
				<div class="header">
					<h3><Icon name="marker" />Next tides</h3>
				</div>
				<div class="content">
					<div class="sidebar-conditions sidebar-conditions--tides">
						<TidesWidget />
					</div>
				</div>
			</div>
		)
	}

	{
		showAds && (
			<ins
				class="adsbygoogle"
				style="display:block"
				data-ad-client={SITE.adsenseClient}
				data-ad-slot="7221027714"
				data-ad-format="auto"
				data-full-width-responsive="true"
			/>
			<script is:inline>
				(adsbygoogle = window.adsbygoogle || []).push({});
			</script>
		)
	}
</aside>
