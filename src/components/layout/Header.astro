---
import Nav from './Nav.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import { SITE } from '../../lib/site';

interface Props {
	heroImage?: { src: string; alt?: string } | null;
	breadcrumbs?: { label: string; href?: string }[];
	isFrontPage?: boolean;
}

const {
	heroImage = null,
	breadcrumbs = [],
	isFrontPage = false,
} = Astro.props;

const TitleTag = isFrontPage ? 'h1' : 'p';
---

<a class="skip-link screen-reader-text" href="#primary">Skip to content</a>

<header id="masthead" class="site-header">
	<div class="header-container">
		<div class="site-branding">
			<a href="/" rel="home" class="custom-logo-link">
				<!-- TODO: replace with optimized logo asset -->
				<span class="custom-logo-placeholder" aria-hidden="true"></span>
			</a>
			<TitleTag class="site-title">
				<a href="/" rel="home">{SITE.name}</a>
			</TitleTag>
		</div>

		<Nav />
	</div>
</header>

{
	heroImage && (
		<div class="banner-image-container">
			<img class="banner-image" src={heroImage.src} alt={heroImage.alt ?? ''} loading="eager" />
		</div>
	)
}

<Breadcrumbs items={breadcrumbs} />
