---
import Icon from '../ui/Icon.astro';
import { FOOTER_COLUMNS, SOCIAL_LINKS } from '../../lib/nav';
import { SITE } from '../../lib/site';

const year = new Date().getFullYear();
---

<footer id="colophon" class="site-footer">
	<div class="container">
		<div class="grid">
			{
				FOOTER_COLUMNS.map((col) => (
					<div class="column">
						<h2 class="footer-title">{col.title}</h2>
						<ul>
							{col.links.map((link) => (
								<li>
									<a href={link.href}>{link.label}</a>
								</li>
							))}
						</ul>
						{col.title.startsWith('Contact') && (
							<ul class="social-media" aria-label={`${SITE.name} social media`}>
								{SOCIAL_LINKS.map((s) => (
									<li>
										<a href={s.href} target="_blank" rel="noopener noreferrer">
											<Icon name={s.icon} />
											<span class="sr-only">{`${SITE.name} on ${s.name}`}</span>
											<span class="sr-only"> (opens in new tab)</span>
										</a>
									</li>
								))}
							</ul>
						)}
					</div>
				))
			}
		</div>
		<div class="site-info">
			<hr />
			<p>&copy; {SITE.name} {year}</p>
		</div>
	</div>
</footer>
