---
/**
 * Page hero / banner image. Wraps Astro's `<Image>` so the LCP
 * candidate on most pages renders as a content-hashed AVIF/WebP/JPG
 * with a responsive `srcset` and `priority` (eager + decoding=sync
 * + fetchpriority=high) when used above the fold.
 *
 * Use the `priority` prop on the page hero of every editorial page;
 * it tells the browser to fetch this image first and decode it
 * synchronously, which is the single biggest LCP lever after
 * format conversion. Defaults to `true` because every consumer
 * today is using BannerImage as the hero.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import styles from './BannerImage.module.scss';

interface Props {
	src: ImageMetadata;
	alt?: string;
	priority?: boolean;
}

const { src, alt = '', priority = true } = Astro.props;
---

<div class={styles.wrap}>
	<Image
		class={styles.image}
		src={src}
		alt={alt}
		layout="full-width"
		priority={priority}
		formats={['avif', 'webp']}
		widths={[640, 960, 1280, 1920]}
		sizes="100vw"
	/>
</div>
