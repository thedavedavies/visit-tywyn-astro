---
/**
 * Horizontal list row for `things-to-do`. Mirrors the legacy
 * `archive-things_to_do.php` structure (image left + h3/excerpt
 * right). Visually identical to VenueCard but kept separate so
 * activity-specific fields can grow without affecting eating.
 */
import Icon from '../Icon/Icon.astro';
import styles from './ActivityCard.module.scss';

interface Props {
	href: string;
	title: string;
	summary?: string;
	address?: string;
	heroImage?: { src: string; alt?: string };
	headingLevel?: 2 | 3;
}

const { href, title, summary, address, heroImage, headingLevel = 3 } = Astro.props;
const HTag = `h${headingLevel}` as 'h2' | 'h3';
---

<article class={styles.row}>
	<a href={href} class={styles.media}>
		{heroImage && <img src={heroImage.src} alt={heroImage.alt ?? title} loading="lazy" />}
	</a>
	<div class={styles.body}>
		<HTag class={styles.title}>
			<a href={href}>{title}</a>
		</HTag>
		{
			address && (
				<p class={styles.address}>
					<Icon name="marker" />
					<span>{address}</span>
				</p>
			)
		}
		{summary && <p class={styles.summary}>{summary}</p>}
	</div>
</article>
