---
/**
 * Gallery grid. Replaces the legacy flexslider + lity stack with
 * a native `<dialog>`-based lightbox: zero JS framework needed.
 *
 * Behaviour:
 *   - Thumbnails laid out in a responsive grid.
 *   - Clicking a thumbnail opens the corresponding `<dialog>`.
 *   - Escape / clicking the backdrop closes it.
 *
 * The dialog wiring lives in a small inline `<script>` at the
 * bottom of this component so it travels with the markup.
 */
import { Picture, Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import styles from './Gallery.module.scss';

interface GalleryImage {
	src: ImageMetadata;
	alt?: string;
}

interface Props {
	images: GalleryImage[];
	label?: string;
}

const { images, label = 'Gallery' } = Astro.props;
---

{
	images.length > 0 && (
		<section class={styles.gallery} aria-label={label}>
			<ul class={styles.grid} role="list">
				{images.map((img, idx) => {
					// Frontmatter may omit `alt`; fall back to a positional
					// label so the wrapping <button>'s accessible name is
					// the image alt (no extra aria-label needed). `||` not
					// `??` so an empty-string alt also falls through.
					const altText = img.alt || `${label} image ${idx + 1} of ${images.length}`;
					return (
						<li>
							<button class={styles.thumb} type="button" data-gallery-open={idx}>
								<Picture
									src={img.src}
									alt={altText}
									loading="lazy"
									formats={['avif', 'webp']}
									widths={[200, 320, 480]}
									sizes="(min-width: 768px) 200px, 50vw"
								/>
							</button>
						</li>
					);
				})}
			</ul>

			{images.map((img, idx) => {
				const altText = img.alt || `${label} image ${idx + 1} of ${images.length}`;
				return (
					<dialog class={styles.lightbox} data-gallery-dialog={idx}>
						<form method="dialog" class={styles.lightboxForm}>
							<button class={styles.lightboxClose} type="submit" aria-label="Close gallery">×</button>
						</form>
						<Image
							src={img.src}
							alt={altText}
							loading="lazy"
							widths={[640, 960, 1280, 1920]}
							sizes="(min-width: 1024px) 80vw, 100vw"
						/>
					</dialog>
				);
			})}

			<script is:inline>
				(() => {
					// Track which thumbnail opened each dialog so we can
					// restore focus to it on close. Without this the
					// browser drops focus to <body>, leaving keyboard
					// users with no anchor in the gallery grid.
					let lastTrigger = null;
					document.querySelectorAll('[data-gallery-open]').forEach((btn) => {
						btn.addEventListener('click', () => {
							const id = btn.getAttribute('data-gallery-open');
							const dialog = document.querySelector(`[data-gallery-dialog="${id}"]`);
							if (dialog && typeof dialog.showModal === 'function') {
								lastTrigger = btn;
								dialog.showModal();
							}
						});
					});
					document.querySelectorAll('[data-gallery-dialog]').forEach((dialog) => {
						dialog.addEventListener('click', (event) => {
							if (event.target === dialog) dialog.close();
						});
						dialog.addEventListener('close', () => {
							if (lastTrigger && typeof lastTrigger.focus === 'function') {
								lastTrigger.focus();
								lastTrigger = null;
							}
						});
					});
				})();
			</script>
		</section>
	)
}
