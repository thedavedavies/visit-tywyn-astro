---
/**
 * Inlines an SVG from src/icons/ at build-time.
 *
 * Replaces the WP `visit_tywyn_get_svg()` helper. We inject
 * aria-hidden / focusable so screen readers ignore decorative
 * icons. Pair with a visually-hidden label when the icon is the
 * only thing inside a link or button.
 *
 * Usage:
 *   <Icon name="paw" />
 *   <Icon name="paw" class="text-primary" />
 */

const svgFiles = import.meta.glob<string>('/src/icons/*.svg', {
	query: '?raw',
	import: 'default',
	eager: true,
});

interface Props {
	name: string;
	class?: string;
}

const { name, class: className } = Astro.props;
const key = `/src/icons/${name}.svg`;
const raw = svgFiles[key];

if (import.meta.env.DEV && !raw) {
	console.warn(`[Icon] No SVG found for name="${name}" at ${key}`);
}

let html = raw ?? '';
// Inject the accessibility attributes. Idempotent — replaces only the first <svg.
html = html.replace(/<svg\b/, '<svg aria-hidden="true" focusable="false"');

if (className) {
	// Merge our class onto the root <svg> tag without nuking any existing class.
	if (/<svg\b[^>]*\sclass="/.test(html)) {
		html = html.replace(/(<svg\b[^>]*\sclass=")([^"]*)(")/, `$1$2 ${className}$3`);
	} else {
		html = html.replace(/<svg\b/, `<svg class="${className}"`);
	}
}
---
<Fragment set:html={html} />
