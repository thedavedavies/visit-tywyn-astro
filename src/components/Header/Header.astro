---
/**
 * Site header. The visually-hidden site-name link below the logo is
 * always rendered as `<p>`: the real page H1 lives in the page
 * template (`<EntryHeader>`), and upgrading the masthead branding
 * to an H1 on the home page produced two H1s on the same page,
 * which dilutes the topic signal Google uses for ranking.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Nav from '../Nav/Nav.astro';
import Breadcrumbs from '../Breadcrumbs/Breadcrumbs.astro';
import BannerImage from '../BannerImage/BannerImage.astro';
import { SITE } from '../../lib/site';
import logoSrc from '../../assets/img/site/logo.png';
import styles from './Header.module.scss';

interface Props {
	heroImage?: { src: ImageMetadata; alt?: string } | null;
	breadcrumbs?: { label: string; href?: string }[];
}

const { heroImage = null, breadcrumbs = [] } = Astro.props;
---

<header id="masthead" class={styles.siteHeader}>
	<div class={styles.container}>
		<div class={styles.branding}>
			<a href="/" rel="home" class={styles.logoLink} aria-label={`${SITE.name} home`}>
				<Image
					class={styles.logo}
					src={logoSrc}
					alt={SITE.name}
					layout="fixed"
					loading="eager"
				/>
			</a>
			<p class={styles.titleHidden} aria-hidden="true">
				<a href="/" rel="home" tabindex="-1">{SITE.name}</a>
			</p>
		</div>

		<Nav />
	</div>
</header>

{heroImage && <BannerImage src={heroImage.src} alt={heroImage.alt} />}

<Breadcrumbs items={breadcrumbs} />
