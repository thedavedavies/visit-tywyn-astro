---
import { getEntry, render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import EntryHeader from '../components/EntryHeader/EntryHeader.astro';
import EmbedFrame from '../components/EmbedFrame/EmbedFrame.astro';
import Icon from '../components/Icon/Icon.astro';
import { webPage } from '../lib/jsonld';

const page = await getEntry('pages', 'webcam');
const Content = page ? (await render(page)).Content : null;

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Webcam' },
];

const jsonLd = webPage({
	title: page?.data.seo?.title ?? page?.data.title ?? 'Tywyn beach webcam',
	description: page?.data.seo?.description ?? page?.data.subtitle,
	url: Astro.url,
	image: page?.data.hero_image?.src,
});
---

<PageLayout
	title={page?.data.seo?.title ?? page?.data.title ?? 'Tywyn beach webcam'}
	description={page?.data.seo?.description ?? page?.data.subtitle}
	heroImage={page?.data.hero_image}
	breadcrumbs={breadcrumbs}
	jsonLd={jsonLd}
>
	<EntryHeader
		title={page?.data.title ?? 'Tywyn beach webcam'}
		subtitle={page?.data.subtitle}
	/>

	<div class="entry-content">
		{Content && <Content />}

		<div class="webcam">
			<small class="webcam__instruction">
				Just press the <Icon name="play" /> button below to view the Tywyn Seafront livestream.
			</small>
			<EmbedFrame src="https://www.tywynctc.co.uk/webrufg-hdd-h09ys.html" title="Tywyn seafront live webcam" />
			<p>
				The Tywyn webcam is provided by <a href="https://tywynctc.co.uk/" target="_blank" rel="noopener noreferrer nofollow"
					>Tywyn CTC<span class="sr-only"> (opens in new tab)</span></a>.
			</p>
		</div>
	</div>
</PageLayout>

<style lang="scss">
	@use '../styles/abstracts/variables' as *;

	.webcam {
		margin: $space-6 0;
	}

	.webcam__instruction {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: $space-2;
		margin-bottom: $space-3;
		color: $color-text-muted;

		:global(svg) {
			width: 18px;
			height: 18px;
		}
	}
</style>
