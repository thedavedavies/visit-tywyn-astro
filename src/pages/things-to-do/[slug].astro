---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import EntryHeader from '../../components/EntryHeader/EntryHeader.astro';
import VenueMap from '../../components/VenueMap/VenueMap.astro';
import Gallery from '../../components/Gallery/Gallery.astro';

export async function getStaticPaths() {
	const activities = await getCollection('things-to-do');
	return activities.map((activity) => ({
		params: { slug: activity.id },
		props: { activity },
	}));
}

const { activity } = Astro.props;
const { Content } = await render(activity);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Things to do', href: '/things-to-do/' },
	{ label: activity.data.title },
];

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'TouristAttraction',
	name: activity.data.title,
	url: `https://visit-tywyn.co.uk/things-to-do/${activity.id}/`,
	description: activity.data.summary,
	telephone: activity.data.phone,
	address: activity.data.address,
	image: activity.data.hero_image?.src,
	geo: activity.data.geo
		? {
				'@type': 'GeoCoordinates',
				latitude: activity.data.geo.lat,
				longitude: activity.data.geo.lng,
		  }
		: undefined,
	sameAs: activity.data.social ? Object.values(activity.data.social).filter(Boolean) : undefined,
};
---

<PageLayout
	title={activity.data.seo?.title ?? activity.data.title}
	description={activity.data.seo?.description ?? activity.data.summary}
	canonical={activity.data.seo?.canonical}
	ogImage={activity.data.seo?.og_image ?? activity.data.hero_image?.src}
	noindex={activity.data.seo?.noindex}
	heroImage={activity.data.hero_image}
	breadcrumbs={breadcrumbs}
	jsonLd={jsonLd}
	sidebarProps={{
		thingsToDo: {
			title: activity.data.title,
			website: activity.data.website,
			phone: activity.data.phone,
			grid_reference: activity.data.grid_reference,
		},
	}}
>
	<EntryHeader title={activity.data.title} subtitle={activity.data.subtitle ?? activity.data.summary} />

	<div class="entry-content">
		<Content />
	</div>

	<Gallery images={activity.data.gallery} label={`${activity.data.title} gallery`} />

	{
		activity.data.geo && (
			<VenueMap
				lat={activity.data.geo.lat}
				lng={activity.data.geo.lng}
				title={activity.data.title}
				zoom={activity.data.geo.zoom}
			/>
		)
	}
</PageLayout>
