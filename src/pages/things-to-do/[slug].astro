---
/**
 * Single things-to-do entry. Mirrors `template-parts/content.php`
 * (the fallback used because no content-things_to_do.php exists):
 *   - entry-header: H1 + optional H2 entry-subtitle + optional
 *     single-address paragraph
 *   - the_content() (post body)
 *   - <h2>{title} Gallery</h2> + flexslider (if gallery has items)
 *
 * The legacy template does NOT render a map for things-to-do
 * detail pages even when `google_map` is set — we mirror that.
 */
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import EntryHeader from '../../components/EntryHeader/EntryHeader.astro';
import Gallery from '../../components/Gallery/Gallery.astro';
import Icon from '../../components/Icon/Icon.astro';
import RelatedItems from '../../components/RelatedItems/RelatedItems.astro';
import { touristAttraction } from '../../lib/jsonld';
import { seededShuffle } from '../../lib/random';

export async function getStaticPaths() {
	const activities = await getCollection('things-to-do');
	return activities.map((activity) => ({
		params: { slug: activity.id },
		props: { activity, allActivities: activities },
	}));
}

const { activity, allActivities } = Astro.props;
const { Content } = await render(activity);

// Deterministic shuffle so each activity page always offers the
// same 4 "more to explore" entries; avoids the non-uniform bias
// of `sort(Math.random)` and the per-build cache-thrash it causes.
const related = seededShuffle(
	allActivities.filter((a) => a.id !== activity.id),
	activity.id
).slice(0, 4);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Things to do', href: '/things-to-do/' },
	{ label: activity.data.title },
];

// Schema-driven `hero_image.src` is now an `ImageMetadata`; reach
// into `.src.src` to get the processed image's hashed URL string
// for JSON-LD and OG meta consumers that need a flat URL.
const heroUrl = activity.data.hero_image?.src.src;

const jsonLd = touristAttraction({
	id: activity.id,
	title: activity.data.title,
	description: activity.data.summary,
	address: activity.data.address,
	phone: activity.data.phone,
	website: activity.data.website,
	heroImage: heroUrl,
	geo: activity.data.geo,
	sameAs: activity.data.social ? Object.values(activity.data.social) : [],
});
---

<PageLayout
	title={activity.data.seo?.title ?? activity.data.title}
	description={activity.data.seo?.description ?? activity.data.summary}
	canonical={activity.data.seo?.canonical}
	ogImage={activity.data.seo?.og_image ?? heroUrl}
	noindex={activity.data.seo?.noindex}
	heroImage={activity.data.hero_image}
	breadcrumbs={breadcrumbs}
	jsonLd={jsonLd}
	sidebarProps={{
		thingsToDo: {
			title: activity.data.title,
			website: activity.data.website,
			phone: activity.data.phone,
			grid_reference: activity.data.grid_reference,
		},
	}}
>
	<header class="entry-header">
		<EntryHeader title={activity.data.title} subtitle={activity.data.subtitle} />
		{
			activity.data.address && (
				<p class="single-address">
					<Icon name="marker" />
					<span>{activity.data.address}</span>
				</p>
			)
		}
	</header>

	<div class="entry-content">
		<Content />

		{
			activity.data.gallery.length > 0 && (
				<>
					<h2>{activity.data.title} Gallery</h2>
					<Gallery images={activity.data.gallery} label={`${activity.data.title} gallery`} />
				</>
			)
		}
	</div>

	<RelatedItems
		heading="More things to do in Tywyn"
		headingId="related-things-to-do"
		items={related.map((a) => ({
			href: `/things-to-do/${a.id}/`,
			title: a.data.title,
			image: a.data.hero_image,
			summary: a.data.summary,
		}))}
	/>
</PageLayout>

<style lang="scss">
	@use '../../styles/abstracts/variables' as *;

	.single-address {
		display: flex;
		align-items: center;
		gap: $space-2;
		margin: 0 0 $space-5;
		color: #6f6f6f;
		line-height: 22px;

		:global(svg) {
			width: 20px;
			height: 20px;
			flex: 0 0 auto;
		}
	}
</style>
