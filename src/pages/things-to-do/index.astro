---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import EntryHeader from '../../components/EntryHeader/EntryHeader.astro';
import ActivityCard from '../../components/ActivityCard/ActivityCard.astro';

const activities = (await getCollection('things-to-do')).sort((a, b) =>
	a.data.title.localeCompare(b.data.title)
);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Things to do' },
];
---

<PageLayout
	title="Things to do in Tywyn"
	description="Attractions, walks, beaches, and family days out in and around Tywyn."
	breadcrumbs={breadcrumbs}
>
	<EntryHeader
		title="Things to do in Tywyn"
		subtitle="From the famous Talyllyn Railway to the long sandy beach — here's what to do during your visit."
	/>

	<ul class="card-grid" role="list">
		{
			activities.map((activity) => (
				<li>
					<ActivityCard
						href={`/things-to-do/${activity.id}/`}
						title={activity.data.title}
						summary={activity.data.summary}
						address={activity.data.address}
						heroImage={activity.data.hero_image}
					/>
				</li>
			))
		}
	</ul>
</PageLayout>

<style lang="scss">
	@use '../../styles/abstracts/variables' as *;

	.card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: $space-5;
		margin: 0;
		padding: 0;
		list-style: none;

		li {
			margin: 0;
		}
	}
</style>
