---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import EntryHeader from '../../components/EntryHeader/EntryHeader.astro';
import ActivityCard from '../../components/ActivityCard/ActivityCard.astro';
import AdSlot from '../../components/AdSlot/AdSlot.astro';
import { itemList } from '../../lib/jsonld';

const activities = (await getCollection('things-to-do')).sort((a, b) =>
	a.data.title.localeCompare(b.data.title)
);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Things to do' },
];

const jsonLd = itemList(
	'Things to do in Tywyn',
	activities.map((activity) => ({
		url: `/things-to-do/${activity.id}/`,
		name: activity.data.title,
		image: activity.data.hero_image?.src,
		description: activity.data.summary,
	}))
);
---

<PageLayout
	title="The best things to do in Tywyn (with photos!)"
	description="Attractions, walks, beaches, and family days out in and around Tywyn."
	breadcrumbs={breadcrumbs}
	jsonLd={jsonLd}
>
	<EntryHeader
		title="Things to do in Tywyn"
		subtitle="Top things to see and do in Tywyn this year"
	/>

	<div class="entry-content">
		<p>
			Come and discover all of the best things to do and places to see in Tywyn this year. From
			stunning walks in some of Wales' most iconic landscapes, to trips out and museums.
		</p>
	</div>

	<div class="activity-list">
		{
			activities.flatMap((activity, idx) => {
				const card = (
					<ActivityCard
						href={`/things-to-do/${activity.id}/`}
						title={activity.data.title}
						summary={activity.data.summary}
						address={activity.data.address}
						heroImage={activity.data.hero_image}
					/>
				);
				const showAd = (idx + 1) % 3 === 0 && idx < activities.length - 1;
				return showAd
					? [card, <AdSlot slot="7221027714" placement="in-feed" />]
					: [card];
			})
		}
	</div>
</PageLayout>

<style lang="scss">
	@use '../../styles/abstracts/variables' as *;

	.activity-list {
		margin-block-start: $space-6;
		display: flex;
		flex-direction: column;
		gap: $space-4;
	}
</style>
