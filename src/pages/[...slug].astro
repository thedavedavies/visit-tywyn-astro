---
/**
 * Catch-all for editorial pages stored in the `pages` collection.
 *
 * Maps `src/content/pages/<slug>.md` → `/<slug>/`.
 *
 * Excluded:
 *   - `home-page` (handled by `src/pages/index.astro`)
 *   - any slug that conflicts with a hand-rolled route file
 *     (e.g. `/where-to-stay/`, `/webcam/`, `/dog-friendly-cafes/`).
 *     Astro's filesystem routing resolves the explicit file before
 *     this catch-all.
 *   - any slug that is already handled by a 301 in
 *     `public/_redirects` (currently `/cinema/`, `/tywyn-beach/`).
 *     We don't want both a built page and a redirect for the same
 *     URL — the sitemap would advertise duplicates and the host
 *     would serve a 200 ahead of the redirect.
 *
 * For pages whose body content has an `<h4>question</h4>` /
 * answer pattern (currently only `/explore-tywyn/`) we additionally
 * emit FAQPage JSON-LD so they're eligible for FAQ rich results.
 */
import { getCollection, render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import EntryHeader from '../components/EntryHeader/EntryHeader.astro';
import { webPage, faqPage } from '../lib/jsonld';
import { extractFaq } from '../lib/markdown';

export async function getStaticPaths() {
	// Slugs that have hand-rolled route files — exclude them from
	// the catch-all so we don't double-emit.
	const bespokeSlugs = new Set([
		'home-page',
		'webcam',
		'dog-friendly-cafes',
		'where-to-stay',
		'events',
	]);
	// Slugs whose URL is owned by a 301 redirect in public/_redirects.
	// Building these as pages would create duplicate URLs in the
	// sitemap and a 200/301 race at the host edge.
	const redirectedSlugs = new Set(['cinema', 'tywyn-beach']);

	const pages = await getCollection(
		'pages',
		(entry) => !bespokeSlugs.has(entry.id) && !redirectedSlugs.has(entry.id)
	);
	return pages.map((page) => ({
		params: { slug: page.id },
		props: { page },
	}));
}

const { page } = Astro.props;
const { Content } = await render(page);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: page.data.title },
];

const updatedIso = page.data.updated ? page.data.updated.toISOString() : undefined;

// Use `||` (not `??`) on string fallbacks: empty strings from
// frontmatter should fall through to the next option, not stick.
const seoTitle = page.data.seo?.title || page.data.title;
const seoDescription = page.data.seo?.description || page.data.subtitle;
const seoOgImage = page.data.seo?.og_image || page.data.hero_image?.src;

const jsonLd: (Record<string, unknown> | null)[] = [
	webPage({
		title: seoTitle,
		description: seoDescription,
		url: Astro.url,
		image: seoOgImage,
		dateModified: updatedIso,
		// Speakable selectors must match the rendered DOM. CSS
		// modules hash component-scoped class names, so we target
		// data-attributes set by EntryHeader instead. Voice
		// assistants will read this and stop.
		speakableSelector: ['[data-speakable="title"]'],
	}),
	// FAQPage rich-result eligibility — only the /explore-tywyn/
	// page has a `<div class="faqs">` block; extractFaq returns
	// an empty array for everything else.
	faqPage(extractFaq(page.body ?? '')),
];
---

<PageLayout
	title={seoTitle}
	description={seoDescription}
	canonical={page.data.seo?.canonical}
	ogImage={seoOgImage}
	noindex={page.data.seo?.noindex}
	heroImage={page.data.hero_image}
	breadcrumbs={breadcrumbs}
	jsonLd={jsonLd}
	modifiedTime={updatedIso}
>
	<EntryHeader title={page.data.title} subtitle={page.data.subtitle} />
	<div class="entry-content">
		<Content />
	</div>
</PageLayout>
