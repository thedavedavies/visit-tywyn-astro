---
/**
 * Catch-all for editorial pages stored in the `pages` collection.
 *
 * Maps `src/content/pages/<slug>.md` → `/<slug>/`.
 *
 * Excluded:
 *   - `home-page` (handled by `src/pages/index.astro`)
 *   - any slug that conflicts with a hand-rolled route file
 *     (e.g. `/where-to-stay/`, `/webcam/`, `/dog-friendly-cafes/`).
 *     Astro's filesystem routing resolves the explicit file before
 *     this catch-all.
 */
import { getCollection, render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import EntryHeader from '../components/EntryHeader/EntryHeader.astro';

export async function getStaticPaths() {
	const bespokeSlugs = new Set(['home-page', 'webcam', 'dog-friendly-cafes', 'where-to-stay']);
	const pages = await getCollection('pages', (entry) => !bespokeSlugs.has(entry.id));
	return pages.map((page) => ({
		params: { slug: page.id },
		props: { page },
	}));
}

const { page } = Astro.props;
const { Content } = await render(page);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: page.data.title },
];
---

<PageLayout
	title={page.data.seo?.title ?? page.data.title}
	description={page.data.seo?.description ?? page.data.subtitle}
	canonical={page.data.seo?.canonical}
	ogImage={page.data.seo?.og_image ?? page.data.hero_image?.src}
	noindex={page.data.seo?.noindex}
	heroImage={page.data.hero_image}
	breadcrumbs={breadcrumbs}
>
	<EntryHeader title={page.data.title} subtitle={page.data.subtitle} />
	<div class="entry-content">
		<Content />
	</div>
</PageLayout>
