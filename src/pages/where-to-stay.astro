---
/**
 * Where-to-stay parent page. Renders the WP `where-to-stay` page
 * content followed by 4 category cards linking to the holiday-
 * accommodation landings.
 */
import { getCollection, getEntry, render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import EntryHeader from '../components/EntryHeader/EntryHeader.astro';
import StayCategoryCard from '../components/StayCategoryCard/StayCategoryCard.astro';
import { itemList, webPage } from '../lib/jsonld';

const page = await getEntry('pages', 'where-to-stay');
const Content = page ? (await render(page)).Content : null;

const categories = (await getCollection('stay-categories')).sort(
	(a, b) => a.data.menu_order - b.data.menu_order
);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Where to stay' },
];

const jsonLd = [
	webPage({
		title: page?.data.seo?.title ?? page?.data.title ?? 'Where to stay in Tywyn',
		description:
			page?.data.seo?.description ??
			'Find holiday accommodation in Tywyn — camping, caravans, self-catering cottages, and B&Bs.',
		url: Astro.url,
		image: page?.data.hero_image?.src,
	}),
	itemList(
		'Tywyn accommodation categories',
		categories.map((category) => ({
			url: `/holiday-accommodation/${category.id}/`,
			name: category.data.title,
			image: category.data.hero_image?.src,
			description: category.data.intro,
		}))
	),
];
---

<PageLayout
	title={page?.data.seo?.title ?? page?.data.title ?? 'Where to stay in Tywyn'}
	description={
		page?.data.seo?.description ?? 'Find holiday accommodation in Tywyn — camping, caravans, self-catering cottages, and B&Bs.'
	}
	heroImage={page?.data.hero_image}
	breadcrumbs={breadcrumbs}
	jsonLd={jsonLd}
>
	<EntryHeader
		title={page?.data.title ?? 'Where to stay in Tywyn'}
		subtitle={page?.data.subtitle}
	/>

	{
		Content && (
			<div class="entry-content">
				<Content />
			</div>
		)
	}

	<section class="stay-categories" aria-labelledby="stay-categories-title">
		<h2 id="stay-categories-title">Browse by type</h2>
		<ul role="list">
			{
				categories.map((category) => (
					<li>
						<StayCategoryCard
							href={`/holiday-accommodation/${category.id}/`}
							title={category.data.title}
							intro={category.data.intro}
							heroImage={category.data.hero_image}
						/>
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>

<style lang="scss">
	@use '../styles/abstracts/variables' as *;

	.stay-categories {
		margin: $space-7 0;

		h2 {
			margin: 0 0 $space-4;
			font-size: 1.4rem;
		}

		ul {
			margin: 0;
			padding: 0;
			list-style: none;
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
			gap: $space-5;

			li {
				margin: 0;
			}
		}
	}
</style>
