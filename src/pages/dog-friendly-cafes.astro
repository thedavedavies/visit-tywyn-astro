---
/**
 * Dog friendly cafes page. Mirrors
 * `template-parts/content-dog-friendly-cafes.php`:
 *   - page entry-header (H1 + page_subtitle)
 *   - the_content() (page body)
 *   - <ul class="cafe-list"> with image-left, h2-title-right
 *     items pulled from the `eating` CPT where dog_friendly=yes
 */
import { getCollection, getEntry, render } from 'astro:content';
import { Picture } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import EntryHeader from '../components/EntryHeader/EntryHeader.astro';
import { itemList } from '../lib/jsonld';

const page = await getEntry('pages', 'dog-friendly-cafes');
const Content = page ? (await render(page)).Content : null;

const dogFriendly = (await getCollection('eating', (e) => e.data.dog_friendly === true)).sort(
	(a, b) => a.data.title.localeCompare(b.data.title)
);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Dog friendly cafes' },
];

const jsonLd = itemList(
	'Dog friendly cafes and restaurants in Tywyn',
	dogFriendly.map((venue) => ({
		url: `/eating/${venue.id}/`,
		name: venue.data.title,
		image: venue.data.photo?.src.src,
		description: venue.data.summary,
	}))
);
---

<PageLayout
	title={page?.data.seo?.title ?? page?.data.title ?? 'Dog friendly cafes in Tywyn'}
	description={page?.data.seo?.description ?? page?.data.subtitle}
	heroImage={page?.data.hero_image}
	breadcrumbs={breadcrumbs}
	jsonLd={jsonLd}
>
	<EntryHeader
		title={page?.data.title ?? 'Dog friendly cafes in Tywyn'}
		subtitle={page?.data.subtitle}
	/>

	<div class="entry-content">
		{Content && <Content />}

		{
			dogFriendly.length > 0 && (
				<ul class="cafe-list" role="list">
					{dogFriendly.map((venue) => (
						<li>
							<a href={`/eating/${venue.id}/`} class="cafe-list__media">
								{venue.data.photo && (
									<Picture
										src={venue.data.photo.src}
										alt={venue.data.photo.alt ?? venue.data.title}
										loading="lazy"
										formats={['avif', 'webp']}
										widths={[320, 480, 640]}
										sizes="(min-width: 768px) 250px, 100vw"
									/>
								)}
							</a>
							<div class="cafe-list__body">
								<h2>
									<a href={`/eating/${venue.id}/`}>{venue.data.title}</a>
								</h2>
								{venue.data.summary && <p>{venue.data.summary}</p>}
							</div>
						</li>
					))}
				</ul>
			)
		}
	</div>
</PageLayout>

<style lang="scss">
	@use '../styles/abstracts/variables' as *;
	@use '../styles/abstracts/mixins' as *;

	.cafe-list {
		margin: $space-6 0 0;
		padding: 0;
		list-style: none;

		li {
			display: grid;
			gap: $space-5;
			grid-template-columns: 1fr;
			margin-bottom: $space-5;
			padding-bottom: $space-5;
			border-bottom: 1px solid rgba($color-sidebar-bg, 0.15);

			@include breakpoint(md) {
				grid-template-columns: minmax(0, 250px) minmax(0, 1fr);
				align-items: start;
			}

			&:last-child {
				border-bottom: 0;
			}
		}

		.cafe-list__media {
			display: block;
			overflow: hidden;
			border-radius: $radius-md;
			background: $color-bg-alt;

			img {
				width: 100%;
				aspect-ratio: 4 / 3;
				object-fit: cover;
				display: block;
			}
		}

		.cafe-list__body {
			min-width: 0;

			h2 {
				margin: 0 0 $space-2;
				font-size: 1.25rem;

				a {
					color: $color-primary;
					text-decoration: none;
					border-bottom: 2px solid rgba($color-primary, 0.2);

					&:hover,
					&:focus-visible {
						border-bottom-color: $color-primary;
					}
				}
			}

			p {
				margin: 0;
			}
		}
	}
</style>
