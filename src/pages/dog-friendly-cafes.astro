---
import { getCollection, getEntry, render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import Icon from '../components/ui/Icon.astro';

const page = await getEntry('pages', 'dog-friendly-cafes');
const Content = page ? (await render(page)).Content : null;

const dogFriendly = (await getCollection('eating', (e) => e.data.dog_friendly === true)).sort(
	(a, b) => a.data.title.localeCompare(b.data.title)
);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Dog friendly cafes' },
];
---

<PageLayout
	title={page?.data.seo?.title ?? page?.data.title ?? 'Dog friendly cafes in Tywyn'}
	description={page?.data.seo?.description ?? page?.data.subtitle}
	heroImage={page?.data.hero_image}
	breadcrumbs={breadcrumbs}
>
	<header class="entry-header">
		<h1 class="entry-title">{page?.data.title ?? 'Dog friendly cafes in Tywyn'}</h1>
		{page?.data.subtitle && <h2 class="entry-subtitle">{page.data.subtitle}</h2>}
	</header>

	<div class="entry-content">
		{Content && <Content />}
	</div>

	<section class="venue-grid-section" aria-labelledby="dog-friendly-list">
		<h2 id="dog-friendly-list">Dog friendly places to eat</h2>
		{
			dogFriendly.length === 0 ? (
				<p>We're updating our list — check back soon.</p>
			) : (
				<ul class="venue-grid" role="list">
					{dogFriendly.map((venue) => (
						<li class="venue-card">
							<a href={`/eating/${venue.id}/`} class="venue-card__link">
								{venue.data.photo && (
									<div class="venue-card__media">
										<img src={venue.data.photo.src} alt={venue.data.photo.alt} loading="lazy" />
									</div>
								)}
								<div class="venue-card__body">
									<h3 class="venue-card__title">{venue.data.title}</h3>
									{venue.data.summary && <p class="venue-card__summary">{venue.data.summary}</p>}
									<p class="venue-card__pill">
										<Icon name="paw" /> Dog friendly
									</p>
								</div>
							</a>
						</li>
					))}
				</ul>
			)
		}
	</section>
</PageLayout>
