---
import { getCollection, getEntry, render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import EntryHeader from '../components/EntryHeader/EntryHeader.astro';
import VenueCard from '../components/VenueCard/VenueCard.astro';

const page = await getEntry('pages', 'dog-friendly-cafes');
const Content = page ? (await render(page)).Content : null;

const dogFriendly = (await getCollection('eating', (e) => e.data.dog_friendly === true)).sort(
	(a, b) => a.data.title.localeCompare(b.data.title)
);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Dog friendly cafes' },
];
---

<PageLayout
	title={page?.data.seo?.title ?? page?.data.title ?? 'Dog friendly cafes in Tywyn'}
	description={page?.data.seo?.description ?? page?.data.subtitle}
	heroImage={page?.data.hero_image}
	breadcrumbs={breadcrumbs}
>
	<EntryHeader
		title={page?.data.title ?? 'Dog friendly cafes in Tywyn'}
		subtitle={page?.data.subtitle}
	/>

	<div class="entry-content">
		{Content && <Content />}
	</div>

	<section class="dog-friendly" aria-labelledby="dog-friendly-list">
		<h2 id="dog-friendly-list">Dog friendly places to eat</h2>
		{
			dogFriendly.length === 0 ? (
				<p>We're updating our list — check back soon.</p>
			) : (
				<ul role="list">
					{dogFriendly.map((venue) => (
						<li>
							<VenueCard
								href={`/eating/${venue.id}/`}
								title={venue.data.title}
								summary={venue.data.summary}
								address={venue.data.address}
								dogFriendly={true}
								photo={venue.data.photo}
							/>
						</li>
					))}
				</ul>
			)
		}
	</section>
</PageLayout>

<style lang="scss">
	@use '../styles/abstracts/variables' as *;

	.dog-friendly {
		margin: $space-7 0;

		h2 {
			margin: 0 0 $space-4;
			font-size: 1.4rem;
		}

		ul {
			margin: 0;
			padding: 0;
			list-style: none;
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
			gap: $space-5;

			li {
				margin: 0;
			}
		}
	}
</style>
