---
import PageLayout from '../../layouts/PageLayout.astro';
import EntryHeader from '../../components/EntryHeader/EntryHeader.astro';
import EventsSection from '../../components/EventsSection/EventsSection.astro';

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Events' },
];
---

<PageLayout
	title="Events in Tywyn"
	description="Upcoming festivals, fairs, and events in Tywyn and the surrounding villages."
	breadcrumbs={breadcrumbs}
>
	<EntryHeader
		title="Events in Tywyn"
		subtitle="Plan your visit around the next events taking place in Tywyn and nearby."
	/>

	<EventsSection
		title="All upcoming events"
		intro=""
		sectionId="vt-events-page"
		showAllLink={false}
	/>
</PageLayout>
