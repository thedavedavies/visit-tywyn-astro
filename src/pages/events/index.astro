---
import { getEntry, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import EntryHeader from '../../components/EntryHeader/EntryHeader.astro';
import EventsCalendar from '../../components/EventsCalendar/EventsCalendar.astro';
import { featuredEventsMonth, upcomingEvents } from '../../lib/events';
import { collectionPage, eventSchema, itemList } from '../../lib/jsonld';
import { absoluteUrl } from '../../lib/url';

const page = await getEntry('pages', 'events');
const Content = page ? (await render(page)).Content : null;

const breadcrumbs = [{ label: 'Home', href: '/' }, { label: 'Events' }];

// H1 + <title> lead with the month ("June events in Tywyn and Aberdyfi")
// and roll forward a few days before month-end so search engines index
// the next month ahead of time. Recomputed on every ~3-hourly rebuild.
const month = featuredEventsMonth();
const eventsTitle = `${month} events in Tywyn and Aberdyfi`;

// The subtitle + intro copy live in events.md (so the owner can edit the
// prose) but carry a `{month}` placeholder. The subtitle is a plain
// frontmatter string; the body is the compiled markdown HTML. We swap
// the token for the live month in both, falling back to <Content /> if
// the compiled HTML ever isn't available.
const subtitle = page?.data.subtitle?.replaceAll('{month}', month);
const introHtml = (
	page as { rendered?: { html?: string } } | undefined
)?.rendered?.html?.replaceAll('{month}', month);

const events = upcomingEvents();

// Fallback meta description when the events page entry carries no
// Yoast-style seo.description. Shared by the CollectionPage JSON-LD
// and the <PageLayout> meta tag so the two never drift.
const eventsDescription =
	page?.data.seo?.description ??
	'Upcoming festivals, fairs, markets, and community events in Tywyn and the surrounding Dysynni valley villages, with dates, details, and links.';

// CollectionPage wraps the listing intent so crawlers recognise the
// URL as a curated set rather than a single article. The ItemList
// orders the events by their canonical URLs, and each Event node
// stays at the top level so rich-result eligibility is per-event.
const jsonLd: (Record<string, unknown> | null)[] = [
	collectionPage({
		title: eventsTitle,
		description: eventsDescription,
		url: Astro.url,
	}),
	itemList(
		'Upcoming events in Tywyn',
		events
			.filter((ev) => !!ev.primaryUrl)
			.map((ev) => ({
				url: absoluteUrl(ev.primaryUrl!)!,
				name: ev.title,
				image: ev.image ?? undefined,
				description: ev.summary || undefined,
			})),
	),
	...events.map((ev) =>
		eventSchema({
			name: ev.title,
			startIso: ev.startIso,
			endIso: ev.endIso,
			location: ev.location || undefined,
			url: ev.primaryUrl,
			image: ev.image,
			description: ev.summary || undefined,
		}),
	),
];
---

<PageLayout
	title={eventsTitle}
	description={eventsDescription}
	heroImage={page?.data.hero_image}
	breadcrumbs={breadcrumbs}
	jsonLd={jsonLd}
>
	<EntryHeader title={eventsTitle} subtitle={subtitle} />

	{
		introHtml ? (
			<div class="entry-content" set:html={introHtml} />
		) : (
			<div class="entry-content">{Content && <Content />}</div>
		)
	}

	<EventsCalendar sectionId="vt-events-page" />
</PageLayout>
