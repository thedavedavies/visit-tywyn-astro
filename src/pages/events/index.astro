---
import { getEntry, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import EntryHeader from '../../components/EntryHeader/EntryHeader.astro';
import EventsSection from '../../components/EventsSection/EventsSection.astro';
import { upcomingEvents } from '../../lib/events';
import { collectionPage, eventSchema, itemList } from '../../lib/jsonld';
import { absoluteUrl } from '../../lib/url';

const page = await getEntry('pages', 'events');
const Content = page ? (await render(page)).Content : null;

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Events' },
];

const events = upcomingEvents();

// CollectionPage wraps the listing intent so crawlers recognise the
// URL as a curated set rather than a single article. The ItemList
// orders the events by their canonical URLs, and each Event node
// stays at the top level so rich-result eligibility is per-event.
const jsonLd: (Record<string, unknown> | null)[] = [
	collectionPage({
		title: page?.data.seo?.title ?? page?.data.title ?? 'Events in Tywyn',
		description:
			page?.data.seo?.description ??
			'Upcoming festivals, fairs, and events in Tywyn and the surrounding villages.',
		url: Astro.url,
	}),
	itemList(
		'Upcoming events in Tywyn',
		events
			.filter((ev) => !!ev.primaryUrl)
			.map((ev) => ({
				url: absoluteUrl(ev.primaryUrl!)!,
				name: ev.title,
				image: ev.image ?? undefined,
				description: ev.summary || undefined,
			}))
	),
	...events.map((ev) =>
		eventSchema({
			name: ev.title,
			startIso: ev.startIso,
			endIso: ev.endIso,
			location: ev.location || undefined,
			url: ev.primaryUrl,
			image: ev.image,
			description: ev.summary || undefined,
		})
	),
];
---

<PageLayout
	title={page?.data.seo?.title ?? page?.data.title ?? 'Events in Tywyn'}
	description={
		page?.data.seo?.description ??
		'Upcoming festivals, fairs, and events in Tywyn and the surrounding villages.'
	}
	heroImage={page?.data.hero_image}
	breadcrumbs={breadcrumbs}
	jsonLd={jsonLd}
>
	<EntryHeader title={page?.data.title ?? 'Events in Tywyn'} subtitle={page?.data.subtitle} />

	<div class="entry-content">
		{Content && <Content />}
	</div>

	<EventsSection
		title="All upcoming events"
		intro=""
		sectionId="vt-events-page"
		showAllLink={false}
	/>
</PageLayout>
