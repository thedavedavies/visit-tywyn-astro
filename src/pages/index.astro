---
/**
 * Home page. Bespoke render - the WP page id 8 had hand-curated
 * content with intra-site links, plus the events section was
 * inserted via template-parts/content-page.php only on the front
 * page. We reproduce that here.
 */
import PageLayout from '../layouts/PageLayout.astro';
import EntryHeader from '../components/EntryHeader/EntryHeader.astro';
import EventsSection from '../components/EventsSection/EventsSection.astro';
import { SITE } from '../lib/site';
import { touristDestination, eventSchema, webPage } from '../lib/jsonld';
import { upcomingEvents } from '../lib/events';
import surfcamSrc from '../assets/img/heroes/home-surfcam.jpg';

const homeTitle = 'Tywyn Holiday Accommodation, Things to Do and Visit in Tywyn';
const homeDescription =
	'Come and discover Tywyn. From the rolling hills and mountains to the golden beachfront - great food, stunning sunsets, long-lasting memories.';

// `Organization`, `WebSite`, and `BreadcrumbList` are emitted by
// BaseLayout. The home page adds:
//   - `WebPage` to match Yoast (every Yoast page shipped a WebPage;
//     the rebuilt site keeps that node so the JSON-LD graph after
//     cutover is a superset of what was indexed before).
//   - `TouristDestination` (region-specific, richer than WebPage).
//   - one `Event` per upcoming event (each rich-result eligible).
const jsonLd = [
	webPage({
		title: homeTitle,
		description: homeDescription,
		url: Astro.url,
	}),
	touristDestination(),
	...upcomingEvents().map((ev) =>
		eventSchema({
			name: ev.title,
			startIso: ev.startIso,
			endIso: ev.endIso,
			location: ev.location || undefined,
			url: ev.primaryUrl,
			image: ev.image,
			description: ev.summary || undefined,
		}),
	),
];
---

<PageLayout
	title={homeTitle}
	description={homeDescription}
	isFrontPage={true}
	heroImage={{ src: surfcamSrc, alt: '' }}
	jsonLd={jsonLd}
>
	<EntryHeader title="Welcome to Visit Tywyn" subtitle="Come and discover Tywyn" />

	<div class="entry-content">
		<p>
			<strong>
				From the rolling hills and mountains to the tranquil golden beachfront and stunning sunsets,
				the Cardigan Bay Coastline is known across the World for its vast beauty - and Tywyn, right
				in the heart of Wales where the mountains meet the sea, is no exception.
			</strong>
		</p>

		<p>
			The <a href="/wales-coastal-path/">Wales Coastal Path</a> runs right through the town and onto the
			Blue Flag Award beach, and affords views to take your breath away, while the promenade is the perfect
			place for dolphin spotting. On a clear day you can see up the coast with amazing views towards Bardsey
			Island &amp; Pwllheli on the Lleyn Peninsula and South towards Fishguard, Aberporth &amp; Aberystwyth.
		</p>

		<p>
			Families have a huge choice of <a href="/things-to-do/">attractions</a> and <a href="/events/"
				>events</a
			> that will create lasting memories. And at the end of the day, head out to a <a
				href="/eating/">pub or restaurant</a
			> to sample the finest Welsh food and drink and to recount the day's events.
		</p>

		<p>
			When you can no longer keep your eyes open, find the perfect <a href="/where-to-stay/"
				>accommodation</a
			>: a <a href="/holiday-accommodation/bed-and-breakfast/">seaside B&amp;B</a>,
			<a href="/holiday-accommodation/self-catering/">cosy self-catering cottage</a> or one of the popular
			<a href="/holiday-accommodation/caravan/">caravan parks</a>, knowing that in the morning you
			can do it all over again.
		</p>
	</div>

	<EventsSection limit={6} sectionId="vt-home-events" showAllLink={true} />
</PageLayout>
