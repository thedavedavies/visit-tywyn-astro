---
/**
 * Single eating venue. Mirrors `template-parts/content-eating.php`:
 *   - entry-header: H1 + single-address (icon + address)
 *   - photo (full size)
 *   - <h2>About <Title></h2> + about field
 *   - the_content() (post body)
 *   - dog-friendly note (if applicable)
 *   - <h2>Where is <Title></h2> + map + Get directions link
 */
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import EntryHeader from '../../components/EntryHeader/EntryHeader.astro';
import VenueMap from '../../components/VenueMap/VenueMap.astro';
import Icon from '../../components/Icon/Icon.astro';
import RelatedItems from '../../components/RelatedItems/RelatedItems.astro';
import { restaurant } from '../../lib/jsonld';
import { seededShuffle } from '../../lib/random';
import { probeImage } from '../../lib/image-dimensions';

export async function getStaticPaths() {
	const venues = await getCollection('eating');
	return venues.map((venue) => ({
		params: { slug: venue.id },
		props: { venue, allVenues: venues },
	}));
}

const { venue, allVenues } = Astro.props;
const { Content } = await render(venue);

// Pick up to 4 related venues. If this one is dog-friendly, prefer
// other dog-friendly entries; otherwise show any other venues.
// Use seededShuffle so the same slug always produces the same set
// — avoids non-deterministic builds and the bias of `sort(Math.random)`.
const others = allVenues.filter((v) => v.id !== venue.id);
const relatedPool = venue.data.dog_friendly
	? others.filter((v) => v.data.dog_friendly)
	: others;
const related = seededShuffle(relatedPool.length >= 4 ? relatedPool : others, venue.id).slice(0, 4);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Eating', href: '/eating/' },
	{ label: venue.data.title },
];

const directionsHref = venue.data.geo
	? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${venue.data.geo.lat},${venue.data.geo.lng}`)}`
	: null;

const jsonLd = restaurant({
	id: venue.id,
	title: venue.data.title,
	description: venue.data.summary,
	address: venue.data.address,
	phone: venue.data.phone,
	website: venue.data.website,
	dogFriendly: venue.data.dog_friendly,
	photo: venue.data.photo?.src,
	geo: venue.data.geo,
	sameAs: [venue.data.facebook_link, venue.data.trip_advisor_link],
});

const photoDims = venue.data.photo ? probeImage(venue.data.photo.src) : null;
---

<PageLayout
	title={venue.data.seo?.title ?? venue.data.title}
	description={venue.data.seo?.description ?? venue.data.summary}
	canonical={venue.data.seo?.canonical}
	ogImage={venue.data.seo?.og_image ?? venue.data.photo?.src}
	noindex={venue.data.seo?.noindex}
	breadcrumbs={breadcrumbs}
	jsonLd={jsonLd}
	sidebarProps={{
		eating: {
			title: venue.data.title,
			trip_advisor_link: venue.data.trip_advisor_link,
			facebook_link: venue.data.facebook_link,
			dog_friendly: venue.data.dog_friendly,
			website: venue.data.website,
			phone: venue.data.phone,
		},
	}}
>
	<header class="entry-header">
		<EntryHeader title={venue.data.title} />
		{
			venue.data.address && (
				<p class="single-address">
					<Icon name="marker" />
					<span>{venue.data.address}</span>
				</p>
			)
		}
	</header>

	<div class="entry-content">
		{
			venue.data.photo && (
				<div class="entry-photo">
					<img
						src={venue.data.photo.src}
						alt={venue.data.photo.alt ?? venue.data.title}
						width={photoDims?.width}
						height={photoDims?.height}
					/>
				</div>
			)
		}

		<h2>About {venue.data.title}</h2>
		<Content />

		{
			venue.data.dog_friendly && (
				<p class="dog-friendly-note">
					{venue.data.title} is dog friendly, and is a brilliant place to bring your well-behaved
					pup! <a href="/dog-friendly-cafes/">Discover more dog friendly bars, restaurants and cafes</a>.
				</p>
			)
		}

		{
			venue.data.geo && (
				<>
					<h2>Where is {venue.data.title}</h2>
					<VenueMap
						lat={venue.data.geo.lat}
						lng={venue.data.geo.lng}
						title={venue.data.title}
						zoom={venue.data.geo.zoom ?? 16}
					/>
					<p>
						<a href={directionsHref!} target="_blank" rel="noopener noreferrer">
							Get directions in Google Maps
							<span class="sr-only"> (opens in new tab)</span>
						</a>
					</p>
				</>
			)
		}
	</div>

	<RelatedItems
		heading={venue.data.dog_friendly ? 'More dog-friendly places to eat' : 'More places to eat in Tywyn'}
		headingId="related-eating"
		items={related.map((v) => ({
			href: `/eating/${v.id}/`,
			title: v.data.title,
			image: v.data.photo,
			summary: v.data.summary,
		}))}
	/>
</PageLayout>

<style lang="scss">
	@use '../../styles/abstracts/variables' as *;

	.single-address {
		display: flex;
		align-items: center;
		gap: $space-2;
		margin: 0 0 $space-5;
		color: #6f6f6f;
		line-height: 22px;

		:global(svg) {
			width: 20px;
			height: 20px;
			flex: 0 0 auto;
		}
	}

	.entry-photo {
		margin-block: 0 $space-5;

		img {
			width: 100%;
			height: auto;
			display: block;
			border-radius: $radius-md;
		}
	}

	.dog-friendly-note {
		margin: $space-5 0;
		padding: $space-4 $space-5;
		background: rgba($color-primary, 0.06);
		border-left: 4px solid $color-primary;
		border-radius: $radius-sm;
	}
</style>
