---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import EntryHeader from '../../components/EntryHeader/EntryHeader.astro';
import VenueCard from '../../components/VenueCard/VenueCard.astro';
import AdSlot from '../../components/AdSlot/AdSlot.astro';
import { itemList } from '../../lib/jsonld';

const venues = (await getCollection('eating')).sort((a, b) =>
	a.data.title.localeCompare(b.data.title)
);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Eating in Tywyn' },
];

const jsonLd = itemList(
	'Places to eat in Tywyn',
	venues.map((venue) => ({
		url: `/eating/${venue.id}/`,
		name: venue.data.title,
		image: venue.data.photo?.src,
		description: venue.data.summary,
	}))
);
---

<PageLayout
	title="Where to eat in Tywyn?"
	description="Cafes, pubs, restaurants, and tea rooms in Tywyn and the surrounding area."
	heroImage={{ src: '/wp-content/uploads/2022/05/eating-banner.jpg', alt: 'Eating in Tywyn' }}
	breadcrumbs={breadcrumbs}
	jsonLd={jsonLd}
>
	<EntryHeader
		title="Where to eat in Tywyn?"
		subtitle="Love eating? Then you'll love Tywyn's food."
	/>

	<div class="entry-content">
		<p>
			After a long day having fun in Tywyn — why not head to one of Tywyn's great restaurants or
			cafés — and enjoy food cooked by our top local chefs using locally sourced meats and fish.
			With so many to choose from, the problem will be deciding where to eat first!
		</p>
	</div>

	<div class="venue-list">
		{
			venues.map((venue, idx) => (
				<>
					<VenueCard
						href={`/eating/${venue.id}/`}
						title={venue.data.title}
						summary={venue.data.summary}
						address={venue.data.address}
						photo={venue.data.photo}
					/>
					{(idx + 1) % 3 === 0 && idx < venues.length - 1 && <AdSlot slot="7221027714" />}
				</>
			))
		}
	</div>
</PageLayout>

<style lang="scss">
	@use '../../styles/abstracts/variables' as *;

	.venue-list {
		margin-block-start: $space-6;
		display: flex;
		flex-direction: column;
		gap: $space-4;
	}
</style>
