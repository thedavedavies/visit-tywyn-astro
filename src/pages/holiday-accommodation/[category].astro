---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import EntryHeader from '../../components/EntryHeader/EntryHeader.astro';
import BookingSearchList from '../../components/BookingSearchList/BookingSearchList.astro';
import FeaturedStayCard from '../../components/FeaturedStayCard/FeaturedStayCard.astro';
import { webPage, itemList } from '../../lib/jsonld';

export async function getStaticPaths() {
	const categories = await getCollection('stay-categories');
	return categories.map((category) => ({
		params: { category: category.id },
		props: { category },
	}));
}

const { category } = Astro.props;
const { Content } = await render(category);

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Where to stay', href: '/where-to-stay/' },
	{ label: category.data.title },
];

const jsonLd: Record<string, unknown>[] = [
	webPage({
		title: category.data.seo?.title ?? category.data.title,
		description: category.data.seo?.description ?? category.data.intro,
		url: Astro.url,
		image: category.data.hero_image?.src,
	}),
];
if (category.data.featured.length > 0) {
	jsonLd.push(
		itemList(
			`${category.data.title} — featured stays`,
			category.data.featured.map((entry) => ({
				url: entry.url,
				name: entry.name,
				image: entry.image?.src,
				description: entry.summary,
			}))
		)
	);
}
---

<PageLayout
	title={category.data.seo?.title ?? category.data.title}
	description={category.data.seo?.description ?? category.data.intro}
	canonical={category.data.seo?.canonical}
	ogImage={category.data.seo?.og_image ?? category.data.hero_image?.src}
	heroImage={category.data.hero_image}
	breadcrumbs={breadcrumbs}
	jsonLd={jsonLd}
>
	<EntryHeader title={category.data.title} subtitle={category.data.subtitle} />

	<div class="entry-content">
		<p>{category.data.intro}</p>
	</div>

	{
		category.data.featured.length > 0 && (
			<section class="featured-stays" aria-labelledby="featured-stays-title">
				<h2 id="featured-stays-title">Featured stays</h2>
				<ul role="list">
					{category.data.featured.map((entry) => (
						<li>
							<FeaturedStayCard
								href={entry.url}
								name={entry.name}
								summary={entry.summary}
								image={entry.image}
								sponsored={entry.sponsored}
							/>
						</li>
					))}
				</ul>
			</section>
		)
	}

	<BookingSearchList links={category.data.booking_search_links} />

	<div class="entry-content">
		<Content />
	</div>
</PageLayout>

<style lang="scss">
	@use '../../styles/abstracts/variables' as *;

	.featured-stays {
		margin: $space-7 0;

		h2 {
			margin: 0 0 $space-4;
			font-size: 1.4rem;
		}

		ul {
			margin: 0;
			padding: 0;
			list-style: none;
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
			gap: $space-5;

			li {
				margin: 0;
			}
		}
	}
</style>
